#!/bin/sh
# Maven Wrapper script for Unix/Linux/macOS
# Licensed to the Apache Software Foundation (ASF)

set -e

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(pwd)}"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
DOWNLOAD_URL=$(grep "distributionUrl" "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2- | tr -d '\r')
DIST_FILENAME=$(basename "$DOWNLOAD_URL")
DIST_NAME="${DIST_FILENAME%.zip}"
MAVEN_USER_HOME="${MAVEN_USER_HOME:-$HOME/.m2}"
MAVEN_HOME="$MAVEN_USER_HOME/wrapper/dists/$DIST_NAME"

if [ ! -d "$MAVEN_HOME" ]; then
    mkdir -p "$MAVEN_HOME"
    echo "Downloading Maven from $DOWNLOAD_URL"
    curl -L "$DOWNLOAD_URL" -o "$MAVEN_HOME/$DIST_FILENAME"
    unzip -q "$MAVEN_HOME/$DIST_FILENAME" -d "$MAVEN_HOME"
    rm "$MAVEN_HOME/$DIST_FILENAME"
fi

EXEC="$MAVEN_HOME/$DIST_NAME/bin/mvn"
exec "$EXEC" "$@"
