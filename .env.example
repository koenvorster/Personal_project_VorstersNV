# ─── Ollama configuratie ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── ChromaDB configuratie ──────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=bedrijfsdocumenten

# ─── RAG-instellingen ───────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_TOP_K=5

# ─── CORS ───────────────────────────────────────────────────────────────────
# Voeg eventueel extra origins toe, gescheiden door komma
CORS_ORIGINS=["http://localhost:8501","http://frontend:8501"]
