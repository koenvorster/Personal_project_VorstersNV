{
  "realm": "vorstersNV",
  "enabled": true,
  "displayName": "VorstersNV Platform",
  "displayNameHtml": "<b>VorstersNV</b>",
  "loginTheme": "keycloak",
  "accessTokenLifespan": 3600,
  "ssoSessionMaxLifespan": 36000,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "vorstersNV-frontend",
      "name": "VorstersNV Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3000/api/auth/callback/keycloak"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    },
    {
      "clientId": "vorstersNV-api",
      "name": "VorstersNV API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "protocol": "openid-connect"
    }
  ],
  "roles": {
    "realm": [
      { "name": "admin", "description": "Volledige toegang tot het platform" },
      { "name": "klant", "description": "Webshop gebruiker" },
      { "name": "tester", "description": "Test- en lees-toegang" }
    ]
  },
  "users": [
    {
      "username": "koen",
      "email": "koen@vorstersNV.be",
      "firstName": "Koen",
      "lastName": "Vorster",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "demo1234",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    }
  ],
  "groups": [
    {
      "name": "admins",
      "realmRoles": ["admin"]
    },
    {
      "name": "klanten",
      "realmRoles": ["klant"]
    },
    {
      "name": "testers",
      "realmRoles": ["tester"]
    }
  ]
}
